### Message associated with the MAVLINK msg VISION_NAVIGATION_ESTIMATION (Tekever dialect, custom).

# Estimate generated by the VBN system, to be delivered to the autopilot

std_msgs/Header header
geographic_msgs/GeoPoint position

# enum VisionNavigationEstimationFlags
uint8 NAVIGATION_ESTIMATION_FLAGS_UNKNOWN = 0    # Default unknown value
uint8 NAVIGATION_ESTIMATION_FLAGS_OK = 1         # Estimation has valid data
uint8 NAVIGATION_ESTIMATION_FLAGS_ABS_OK = 2     # Absolute position estimation is reliable
uint8 flags             # Flags

float32 pos_error       # Estimate of the position error in metres
